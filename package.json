{
  "name": "ximalaya",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "if exist dist rmdir /s /q dist",
    "build-cs": "vite build -c vite.content.script.config.js",
    "build-tab": "vite build -c vite.config.js",
    "build": "npm run clean && npm run build-cs && npm run build-tab && xcopy /e /i ext\\icons dist\\icons && copy ext\\manifest.json dist\\ && copy ext\\background.js dist\\"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.12",
    "vite": "^5.4.9"
  }
}